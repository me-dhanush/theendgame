generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  lichessId         String             @unique
  username          String
  createdAt         DateTime           @default(now())
  lichessToken      String?
  tournamentsHosted Tournament[]       @relation("HostedTournaments")
  tournamentMembers TournamentMember[]
  lobbyMembers LobbyMember[]
}

model Tournament {
  id     String @id @default(cuid())
  name   String
  hostId String
  host   User   @relation("HostedTournaments", fields: [hostId], references: [id], onDelete: Cascade)

  lobby Lobby?

  rounds  Round[]
  members TournamentMember[]

  timeMinutes   Int
  timeIncrement Int
  rated         Boolean

  status TournamentStatus @default(pending)

  currentRoundNumber Int @default(1)

  createdAt DateTime @default(now())

  @@index([hostId])
}

model Lobby {
  id           String @id @default(cuid())
  tournamentId String @unique
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  members LobbyMember[]
  status  LobbyStatus @default(waiting)
}

model LobbyMember {
  id        String @id @default(cuid())
  lobbyId   String
  lichessId String
  rating    Int?

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [lichessId], references: [lichessId], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([lobbyId, lichessId])
  @@index([lobbyId])
}

model TournamentMember {
  id           String @id @default(cuid())
  tournamentId String
  lichessId    String
  rating       Int

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [lichessId], references: [lichessId], onDelete: Cascade)

  matchesAsPlayer1 Match[] @relation("Player1Matches")
  matchesAsPlayer2 Match[] @relation("Player2Matches")

  wonMatches Match[] @relation("MatchWinner")

  @@unique([tournamentId, lichessId])
  @@index([tournamentId])
  @@index([lichessId])
}

model Round {
  id            String     @id @default(cuid())
  tournamentId  String
  roundNumber   Int
  bulkPairingId String?
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches       Match[]

  @@unique([tournamentId, roundNumber])
  @@index([tournamentId])
}

model Match {
  id      String @id @default(cuid())
  roundId String

  matchNumber Int

  player1Id String?
  player1   TournamentMember? @relation("Player1Matches", fields: [player1Id], references: [id])

  player2Id String?
  player2   TournamentMember? @relation("Player2Matches", fields: [player2Id], references: [id])

  score1 Float @default(0)
  score2 Float @default(0)

  status MatchStatus @default(pending)

  games Game[]

  matchWinnerId String?

  matchWinner TournamentMember? @relation("MatchWinner", fields: [matchWinnerId], references: [id])

  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([roundId, matchNumber])
  @@index([roundId])
  @@index([player1Id])
  @@index([player2Id])
}

model Game {
  id        String @id @default(cuid())
  matchId   String
  lichessId String @unique

  status GameStatus @default(started)

  whiteLichessId String?
  blackLichessId String?

  whiteScore Float?
  blackScore Float?

  gameWinner String?

  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
}

enum LobbyStatus {
  waiting
  full
  started
  cancelled
}

enum TournamentStatus {
  pending
  started
  finished
  cancelled
}

enum MatchStatus {
  pending
  started
  finished
}

enum GameStatus {
  created
  started
  aborted
  mate
  resign
  stalemate
  timeout
  draw
  outoftime
  cheat
  noStart
  unknownFinish
  insufficientMaterialClaim
  variantEnd
}
