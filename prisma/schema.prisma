generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  lichessId String   @unique
  username  String
  createdAt DateTime @default(now())
  lichessToken String?
  tournamentsHosted Tournament[]       @relation("HostedTournaments")
  tournamentMembers TournamentMember[]
}

model Tournament {
  id     String @id @default(cuid())
  name   String
  hostId String
  host   User   @relation("HostedTournaments", fields: [hostId], references: [id], onDelete: Cascade)

  rounds  Round[]
  members TournamentMember[]

  timeMinutes   Int
  timeIncrement Int
  rated         Boolean

  status TournamentStatus @default(pending)

  createdAt DateTime @default(now())

  @@index([hostId])
}

model TournamentMember {
  id           String @id @default(cuid())
  tournamentId String
  lichessId    String
  rating       Int

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [lichessId], references: [lichessId], onDelete: Cascade)

  matchesAsPlayer1 Match[] @relation("Player1Matches")
  matchesAsPlayer2 Match[] @relation("Player2Matches")

  @@unique([tournamentId, lichessId])
  @@index([tournamentId])
  @@index([lichessId])
}

model Round {
  id           String @id @default(cuid())
  tournamentId String
  roundNumber  Int
  bulkPairingId String?
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches    Match[]

  @@index([tournamentId])
  @@unique([tournamentId, roundNumber])
}

model Match {
  id      String @id @default(cuid())
  roundId String

  player1Id String?
  player1   TournamentMember? @relation("Player1Matches", fields: [player1Id], references: [id])

  player2Id String?
  player2   TournamentMember? @relation("Player2Matches", fields: [player2Id], references: [id])

  score1 Float @default(0)
  score2 Float @default(0)

  status MatchStatus @default(pending)

  games Game[]

  matchWinner String?

  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@index([player1Id])
  @@index([player2Id])
}

model Game {
  id        String   @id @default(cuid())
  matchId   String
  lichessId String   @unique

  status GameStatus @default(started)

  whiteLichessId String?
  blackLichessId String?

  whiteScore Float?
  blackScore Float?

  gameWinner String?

  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
}

enum TournamentStatus {
  pending
  started
  finished
  cancelled
}

enum MatchStatus {
  pending
  started
  finished
}

enum GameStatus {
  created
  started
  aborted
  mate
  resign
  stalemate
  timeout
  draw
  outoftime
  cheat
  noStart
  unknownFinish
  insufficientMaterialClaim
  variantEnd
}